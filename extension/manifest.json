{
  "manifest_version": 3,
  "name": "Gleam Link Monitor",
  "version": "0.8.0",
  "description": "Collect Gleam.io links while browsing and auto-enter giveaways.",
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gleam Monitor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://gleam.io/*"],
      "js": ["gleam-entry.js"],
      "css": ["gleam-overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://gleam.io/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
